#include <TFT_eSPI.h>

TFT_eSPI tft = TFT_eSPI();

void setup() {

pinMode(21, OUTPUT);
digitalWrite(21, HIGH); // encender backlight

tft.init();
tft.setRotation(1);

tft.fillScreen(TFT_BLACK);
delay(1000);

tft.fillScreen(TFT_RED);
delay(1000);

tft.fillScreen(TFT_GREEN);
delay(1000);

tft.fillScreen(TFT_BLUE);
delay(1000);

tft.fillScreen(TFT_BLACK);

tft.setTextColor(TFT_WHITE);
tft.setTextSize(3);
tft.setCursor(20,120);
tft.println("CYD OK");
}

void loop() {}
